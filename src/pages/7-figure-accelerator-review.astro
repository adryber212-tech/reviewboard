    gap: 1rem;
  }

  .related-card__placeholder {
    position: relative;
    height: 140px;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    font-weight: 600;
    font-size: 0.85rem;
    color: #fff;
  }

  .related-card__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1e3a5f, #2563eb);
    opacity: 0.8;
