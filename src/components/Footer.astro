---
<footer class="footer">
  <div class="footer__inner">
    <p class="footer__copy">&copy; {new Date().getFullYear()} ReviewBoard. Honest reviews, no fluff.</p>
    <p class="footer__disclosure">We may earn a commission from affiliate links. All opinions are our own.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    margin-top: 4rem;
  }
  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem var(--page-padding);
    text-align: center;
  }
  .footer__copy {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
  .footer__disclosure {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin: 0;
    opacity: 0.7;
  }
</style>
